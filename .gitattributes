# Normalize line endings to LF in the repo; check out as-is.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary

# Lockfile: keep LF, treat as generated in diffs.
bun.lock text eol=lf linguist-generated=true
